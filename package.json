{
  "name": "gh-cleanup-action",
  "version": "0.1.0",
  "description": "Clean useless Tags, Releases and expired GitHub Actions workflow runs automatically",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublish": "run-s format lint test build"
  },
  "keywords": [
    "github-action",
    "cleanup",
    "tags",
    "releases",
    "workflow-runs"
  ],
  "author": "zhiqiang <zhiqiang2033@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.10.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "minimatch": "^10.2.5"
  }
}
